# ============================================================
# OpenAI
# ============================================================

# OpenAI APIキー（https://platform.openai.com/api-keys）
OPENAI_API_KEY=your_openai_api_key_here

# setup-assistant.ts 実行後に発行されるAssistant ID
OPENAI_ASSISTANT_ID=your_assistant_id_here

# ============================================================
# Chatwork
# ============================================================

# Chatwork APIトークン（管理画面 > サービス連携 > API）
CHATWORK_API_TOKEN=your_chatwork_api_token_here

# Bot専用ルームのID（URLの末尾の数字）
CHATWORK_ROOM_ID=your_room_id_here

# BotアカウントのアカウントID（自身の投稿を無視するために使用）
CHATWORK_BOT_ACCOUNT_ID=your_bot_account_id_here

# ============================================================
# セキュリティ（任意）
# ============================================================

# 外部cronからのリクエスト認証用シークレット
CRON_SECRET=your_cron_secret_here
