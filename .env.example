# ============================================================
# Chatwork
# ============================================================

# Chatwork API トークン（管理画面 > API > APIトークン から発行）
CHATWORK_API_TOKEN=your_chatwork_api_token_here

# Bot専用ルームのルームID（ルームURLの末尾の数字）
CHATWORK_ROOM_ID=your_room_id_here

# BotアカウントのアカウントID（自身の投稿を無視するために使用）
# 確認方法: https://api.chatwork.com/v2/me を叩くと account_id が返る
CHATWORK_BOT_ACCOUNT_ID=your_bot_account_id_here

# Webhook署名検証トークン（Chatworkダッシュボードで発行 — Webhook方式のみ必要）
CHATWORK_WEBHOOK_TOKEN=your_webhook_token_here

# ============================================================
# Dify
# ============================================================

# Dify Cloud の API エンドポイント（SaaS版はそのまま使用可）
DIFY_API_URL=https://api.dify.ai/v1

# Dify アプリの API キー（Dify アプリ画面 > API アクセス から発行）
DIFY_API_KEY=your_dify_api_key_here

# ============================================================
# セキュリティ（任意）
# ============================================================

# Vercel Cron Job からのリクエスト認証用シークレット
# Vercel ダッシュボードで設定した値と一致させる
CRON_SECRET=your_cron_secret_here
